# .env file is only for development, and the .env.production file is used for production builds (e.g. Cloudflare Pages)
REACT_APP_BACKEND_API_URL=https://worldinterests-backend.midri.net/
# Google Analytics measurement ID — only needed in production builds.
REACT_APP_GA_ID=G-MDKV0QPB8F

# Public URL of the frontend site — used in sitemap.xml, robots.txt, and JSON-LD structured data.
REACT_APP_SITE_URL=https://worldinterests.midri.net
