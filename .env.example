# URL of the running backend API (see https://github.com/adrianahdez/world-interests-backend)
# .env file is only for development, and the .env.production file is used for production builds (e.g. Cloudflare Pages)
REACT_APP_BACKEND_API_URL=http://localhost:8080/

# Public URL of the frontend site — used in sitemap.xml, robots.txt, and JSON-LD structured data.
# In development this must be left unset (scripts fall back to the hardcoded production URL with a warning).
# Must be set only in .env.production.
REACT_APP_SITE_URL=https://worldinterests.midri.net
